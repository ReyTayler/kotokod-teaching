# Google Sheets (используется только backfill-скриптами; основной runtime — PostgreSQL)
STUDENTS_SPREADSHEET_ID=<google-sheet-id>
JOURNAL_SPREADSHEET_ID=<google-sheet-id>

PORT=3000

# PostgreSQL (источник истины с Phase 3a)
DATABASE_URL=postgresql://journal:journal_dev_password@localhost:5432/journal

# Admin SPA auth (Phase 4.2). Получи значения через:
#   node scripts/admin-set-password.js <свой_пароль>
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_COOKIE_SECRET=
