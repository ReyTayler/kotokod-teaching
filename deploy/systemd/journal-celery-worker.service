# systemd-юнит — KOTOKOD journal Celery worker.
#
# Введено «понемногу» (спеки 2026-07-11 и 2026-07-13). Задачи: email-OTP входа
# (очередь interactive), прогревы кэшей реестра и финансового дашборда (default).
# Один воркер слушает ОБЕ очереди: порядок в -Q даёт приоритет interactive —
# письмо входа не ждёт за фоновыми задачами. concurrency=2 (VPS 2 CPU / 2 ГБ);
# --max-tasks-per-child страхует от утечек памяти. Требует Redis
# (apt install redis-server) и REDIS_URL в .env. Без воркера приложение работает
# синхронно — воркер лишь снимает SMTP/пересчёты с веб-запросов.
#
# Установка (Beget VPS, Ubuntu 22.04, БЕЗ Docker):
#   sudo apt install redis-server
#   sudo cp deploy/systemd/journal-celery-worker.service /etc/systemd/system/
#   # отредактировать User/WorkingDirectory/EnvironmentFile под реальные пути
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now journal-celery-worker
#   sudo systemctl status journal-celery-worker

[Unit]
Description=KOTOKOD journal Celery worker
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=kotokod                                   # ЗАМЕНИТЬ на сервисного пользователя
Group=www-data
WorkingDirectory=/opt/kotokod/journal-backend/journal_django   # ЗАМЕНИТЬ
EnvironmentFile=/opt/kotokod/journal-backend/.env              # должен содержать REDIS_URL
Environment=DJANGO_SETTINGS_MODULE=config.settings.production
Environment=TZ=Europe/Moscow
ExecStart=/opt/kotokod/journal-backend/journal_django/.venv/bin/celery \
          -A config worker --loglevel=info \
          -Q interactive,default \
          --concurrency=2 --prefetch-multiplier=1 --max-tasks-per-child=200

Restart=on-failure
RestartSec=5

# Hardening (как journal-django.service)
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
